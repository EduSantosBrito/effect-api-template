{
  "name": "api-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "build": "tsgo -b",
    "typecheck": "tsgo",
    "check": "tsgo && oxlint src && oxfmt --check src",
    "fmt": "oxfmt --write src",
    "lint": "oxlint --fix src",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "trust:verify": "trust check --layer=all src/",
    "tsgo:setup": "npx @effect/tsgo setup",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.51"
  },
  "devDependencies": {
    "@effect/platform-node": "^4.0.0-beta.51",
    "@effect/tsgo": "0.5.1",
    "@effect/vitest": "^4.0.0-beta.51",
    "vitest": "^4.1.4",
    "@typescript/native-preview": "latest"
  }
}
